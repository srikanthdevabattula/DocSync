# Client environment variables (copy to .env.local for local development)
# Next.js only exposes variables prefixed with NEXT_PUBLIC_ to the browser.

# Backend API base URL (must match server PORT and /api/v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# App branding shown in the UI and page titles
NEXT_PUBLIC_APP_NAME=DocSync
