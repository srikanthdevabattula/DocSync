# ===========================================
# Root Environment Variables (Reference)
# Copy to client/.env.local and server/.env
# ===========================================

# --- Client (Next.js) — copy to client/.env.local ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_APP_NAME=DocSync

# --- Server (Express) ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/collabdocs

# JWT (use strong secrets in production — min 32 characters)
JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
